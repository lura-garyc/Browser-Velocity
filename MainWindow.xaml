<Window x:Class="Browser_New.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Velocity Browser v2.6" Height="750" Width="1250"
        Background="#121212" KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="#181818" Margin="2,0" CornerRadius="5,5,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#181818"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#121212" Panel.ZIndex="100">
            <DockPanel>
                <Button Content="+" Click="NewTab_Click" DockPanel.Dock="Right" Width="40" Height="30" Margin="5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                <TabControl x:Name="TabContainer" Background="Transparent" BorderThickness="0" SelectionChanged="TabContainer_SelectionChanged">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" Width="110" TextTrimming="CharacterEllipsis"/>
                                <Button Content="×" Click="CloseTab_Click" Foreground="#888" Background="Transparent" BorderThickness="0" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
            </DockPanel>
        </Grid>

        <Border Grid.Row="1" Background="#202020" BorderBrush="#333" BorderThickness="0,0,0,1" Panel.ZIndex="100">
            <DockPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Click="Back_Click" Width="40" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Click="Forward_Click" Width="40" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Click="Reload_Click" Width="40" Background="Transparent" Foreground="White" BorderThickness="0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📜" Click="History_Click" Width="40" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="⚙" Click="Settings_Click" Width="40" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnGo" Content="GO" Click="Go_Click" Width="65" Margin="5,0" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <TextBox x:Name="UrlTextBox" Height="36" Margin="10,0" VerticalContentAlignment="Center" Background="#2D2D2D" Foreground="White" BorderBrush="#444" Padding="10,0" KeyDown="UrlTextBox_KeyDown"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="DevCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="ViewManager" Grid.Column="0">
                <Grid x:Name="BrowserHost" Visibility="Collapsed"/>

                <Grid x:Name="QuickPanel" Background="#121212">
                    <StackPanel VerticalAlignment="Center">
                        <ListBox x:Name="QuickList" Background="Transparent" BorderThickness="0" MouseDoubleClick="QuickList_MouseDoubleClick">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" MaxWidth="1000"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E" CornerRadius="12" Width="130" Height="130" Margin="10" BorderBrush="#333" BorderThickness="1">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Удалить" Click="DeleteQuickItem_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <StackPanel VerticalAlignment="Center">
                                            <Image Source="{Binding Favicon}" Width="48" Height="48" Margin="0,0,0,10"/>
                                            <TextBlock Text="{Binding Title}" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button x:Name="BtnAddSite" Content="+ Добавить сайт" Click="AddQuickBtn_Click" Width="160" Height="45" Margin="0,30,0,0" Background="#1E1E1E" Foreground="#007ACC" BorderBrush="#007ACC" BorderThickness="1"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border x:Name="SettingsPanel" Grid.Column="0" Grid.ColumnSpan="2" Width="300" HorizontalAlignment="Right" Background="#1E1E1E" Visibility="Collapsed" Panel.ZIndex="1000" BorderBrush="#333" BorderThickness="1,0,0,0">
                <StackPanel Margin="25">
                    <TextBlock x:Name="TxtSettingsTitle" Text="Настройки" FontSize="22" Foreground="White" Margin="0,0,0,25" FontWeight="Bold"/>
                    <Button x:Name="BtnDevTools" Content="DevTools (F12)" Click="DevTools_Click" Height="40" Margin="0,0,0,10"/>
                    <ComboBox x:Name="LangBox" SelectionChanged="LangBox_SelectionChanged" Height="35" Margin="0,0,0,10">
                        <ComboBoxItem Content="Русский"/>
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="Українська"/>
                    </ComboBox>
                    <Button x:Name="BtnClearHist" Content="Очистить историю" Click="ClearHistory_Click" Height="40" Foreground="Red"/>
                    <Button x:Name="BtnCloseSettings" Content="Закрыть" Click="Settings_Click" Margin="0,30,0,0" Height="40" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>