    <UseWPF>true</UseWPF>
    <ApplicationIcon>Velocity Ava.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Velocity Ava.ico" />
  </ItemGroup>

  <ItemGroup>
